# Production environment variables for docker-compose.prod.yml

# Core secrets (required)
DB_PASSWORD=
JWT_SECRET=

# Allowed browser/app origins for gateway CORS
CORS_ORIGINS=https://logiflowapp.z13.web.core.windows.net,http://localhost:4200,capacitor://localhost,http://localhost,https://localhost

# Demo auth users are created by services/gateway/prisma/seed.js.

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://logiflow-api.eastus2.cloudapp.azure.com/api/v1/auth/google/callback
GOOGLE_REDIRECT_FRONTEND=https://logiflowapp.z13.web.core.windows.net
GOOGLE_REDIRECT_FRONTEND_ADMIN=
GOOGLE_REDIRECT_FRONTEND_MOBILE=
GOOGLE_ADMIN_EMAILS=

# Firebase Push (optional)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# n8n (optional)
N8N_HOST=logiflow-api.eastus2.cloudapp.azure.com
N8N_PROTOCOL=https
WEBHOOK_TARGET=
GATEWAY_AUTH_EMAIL=admin@logiflow.app
GATEWAY_AUTH_PASSWORD=Admin2026!
GOOGLE_MAPS_API_KEY=
OPENCLAW_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
