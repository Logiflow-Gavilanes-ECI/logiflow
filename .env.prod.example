# Production environment variables for docker-compose.prod.yml

# Core secrets (required)
DB_PASSWORD=
JWT_SECRET=

# Demo auth (required if you want /auth/login to work)
AUTH_DEMO_USERNAME=
AUTH_DEMO_PASSWORD=
AUTH_DEMO_ROLE=conductor

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.logiflow.app/api/v1/auth/google/callback
GOOGLE_REDIRECT_FRONTEND=https://app.logiflow.app
GOOGLE_REDIRECT_FRONTEND_ADMIN=
GOOGLE_REDIRECT_FRONTEND_MOBILE=
GOOGLE_ADMIN_EMAILS=

# Firebase Push (optional)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# n8n (optional)
N8N_HOST=api.logiflow.app
N8N_PROTOCOL=https
WEBHOOK_TARGET=
GOOGLE_MAPS_API_KEY=
OPENCLAW_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
