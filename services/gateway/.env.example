# LogiFlow Gateway Environment Example

# Required: HTTP port for NestJS gateway
PORT=3002

# Required: PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:logiflow_dev@localhost:5432/logiflow_gateway?schema=public"

# Required: Optimizer gRPC host and port
GRPC_OPTIMIZER_HOST=localhost
GRPC_OPTIMIZER_PORT=50051

# Optional: Explicit path to shared proto contract
GRPC_OPTIMIZER_PROTO_PATH=../../shared/proto/optimizer.proto

# Required: Realtime Socket.io host and port
SOCKETIO_SERVER_HOST=localhost
SOCKETIO_SERVER_PORT=3001

# Required: JWT signing configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Recommended for demo login endpoint (/api/v1/auth/login)
AUTH_DEMO_USERNAME=demo
AUTH_DEMO_PASSWORD=demo123
