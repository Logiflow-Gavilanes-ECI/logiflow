# LogiFlow Gateway Environment Example

# Required: HTTP port for NestJS gateway
PORT=3002

# Required: PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:logiflow_dev@localhost:5432/logiflow_gateway?schema=public"

# Required: Optimizer gRPC host and port
GRPC_OPTIMIZER_HOST=localhost
GRPC_OPTIMIZER_PORT=50051

# Optional: Explicit path to shared proto contract
GRPC_OPTIMIZER_PROTO_PATH=../../shared/proto/optimizer.proto

# Required: Realtime Socket.io host and port
SOCKETIO_SERVER_HOST=localhost
SOCKETIO_SERVER_PORT=3001

# Required: JWT signing configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h
CORS_ORIGINS=https://logiflowapp.z13.web.core.windows.net,http://localhost:4200,capacitor://localhost,http://localhost

# -- Google OAuth 2.0 (optional; email/password auth is also available) --
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/v1/auth/google/callback
GOOGLE_REDIRECT_FRONTEND=http://localhost:4200
GOOGLE_REDIRECT_FRONTEND_ADMIN=
GOOGLE_REDIRECT_FRONTEND_MOBILE=http://localhost:8100
# Emails que se crean como admin en su primer login con Google (separados por coma)
GOOGLE_ADMIN_EMAILS=admin@gmail.com,otro@gmail.com

# ── Firebase Push Notifications (optional — silently disabled if not set) ──
# Get these from: https://console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
