{
  "info": {
    "_postman_id": "lf-sprint1-mock-server-collection",
    "name": "LogiFlow Sprint 1 \u2013 Mock Server",
    "description": "Manual testing collection for the LogiFlow n8n webhook mock server. Tests both the happy path and error handling for the /webhooks/traffic-event endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST Traffic Event \u2013 Valid Payload",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response body has status \\'received\\'', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.equal('received');",
              "});",
              "",
              "pm.test('Response includes vehiclesAffected count', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('vehiclesAffected');",
              "    pm.expect(json.vehiclesAffected).to.be.a('number');",
              "});",
              "",
              "pm.test('Response includes receivedAt timestamp', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('receivedAt');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventType\": \"TRAFFIC_JAM\",\n  \"severity\": \"HIGH\",\n  \"location\": {\n    \"lat\": 4.6889,\n    \"lng\": -74.0669,\n    \"description\": \"Autopista Norte - Calle 100, Bogot\u00e1\"\n  },\n  \"affectedVehicles\": [\"V001\", \"V003\", \"V005\"],\n  \"timestamp\": \"2026-03-02T10:00:00Z\",\n  \"detourRecommended\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3002/webhooks/traffic-event",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3002",
          "path": ["webhooks", "traffic-event"]
        },
        "description": "Sends a valid traffic event payload. Expects HTTP 200 and a response body with status: 'received'."
      },
      "response": []
    },
    {
      "name": "POST Traffic Event \u2013 Empty Body (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response body contains error field', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('error');",
              "    pm.expect(json.error).to.equal('Invalid payload');",
              "});",
              "",
              "pm.test('Response body contains descriptive message', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('message');",
              "    pm.expect(json.message).to.be.a('string');",
              "    pm.expect(json.message.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3002/webhooks/traffic-event",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3002",
          "path": ["webhooks", "traffic-event"]
        },
        "description": "Sends an empty body. Expects HTTP 400 with an error describing the missing required fields."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3002",
      "type": "string"
    }
  ]
}
