# Anthropic API key for OpenClaw model provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Notification Channels (all optional — channels skip if not configured) ──

# Telegram: Get token from @BotFather (/newbot), get chat ID from /getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=

# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
DISCORD_WEBHOOK_URL=

# Slack: https://api.slack.com/apps → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# Email (SMTP): Use Gmail App Password or any SMTP provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LogiFlow Alerts <alerts@logiflow.app>
SMTP_TO=

# Firebase Push: Dispatches via Gateway API endpoint
LOGIFLOW_GATEWAY_URL=http://gateway:3002
LOGIFLOW_GATEWAY_TOKEN=
