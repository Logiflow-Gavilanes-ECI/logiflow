# n8n -> Gateway target URL
# Example: https://<your-ngrok-subdomain>.ngrok-free.dev/api/v1/webhook
WEBHOOK_TARGET=replace_with_your_gateway_webhook_target

# Google Maps Platform API key
# Enable Geocoding API and Directions API in your Google Cloud project.
GOOGLE_MAPS_API_KEY=replace_with_your_google_maps_api_key

# OpenClaw + Telegram
# Get TELEGRAM_BOT_TOKEN from BotFather: https://t.me/BotFather -> /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat id where alerts are delivered
# Get it with: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Anthropic API key for OpenClaw's LLM reasoning layer
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenClaw internal webhook URL (used by n8n to trigger notifications)
# When running via Docker: http://openclaw:18789
# When running locally: http://localhost:18789
OPENCLAW_WEBHOOK_URL=http://openclaw:18789

# ── Multi-Channel Notifications (all optional — channels skip if not set) ──

# Discord: Create a webhook in Server Settings → Integrations → Webhooks → Copy Webhook URL
DISCORD_WEBHOOK_URL=

# Slack: Create an Incoming Webhook at https://api.slack.com/apps → Incoming Webhooks → Add New
SLACK_WEBHOOK_URL=

# Email (SMTP relay): Use Gmail App Password or any SMTP provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LogiFlow Alerts <alerts@logiflow.app>
SMTP_TO=

# Firebase Push (dispatches via Gateway API)
LOGIFLOW_GATEWAY_URL=http://gateway:3002
LOGIFLOW_GATEWAY_TOKEN=
