              "type": "string"
            },
            {
              "id": "s004",
              "name": "detourRecommended",
              "value": "={{ $('Assess Detour').item.json.maps.detourRecommended }}",
              "type": "boolean"
            },
            {
              "id": "s005",
              "name": "alternativeRoutes",
