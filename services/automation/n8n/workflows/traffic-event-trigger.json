      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Normalize Incoming Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const payload = $json;\n\nconst severityRaw = String(payload.severity ?? 'MEDIUM').toUpperCase();\nconst eventTypeRaw = String(payload.eventType ?? 'traffic_jam').toUpperCase();\n\nconst severity = ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'].includes(severityRaw) ? severityRaw : 'MEDIUM';\nconst eventTypeAliases = {\n  TRAFFIC_JAM: 'TRAFFIC_JAM',\n  TRAFFIC: 'TRAFFIC_JAM',\n  ROAD_CLOSURE: 'ROAD_CLOSURE',\n  CLOSURE: 'ROAD_CLOSURE',\n  WEATHER_ALERT: 'WEATHER_ALERT',\n  WEATHER: 'WEATHER_ALERT'\n};\nconst eventType = eventTypeAliases[eventTypeRaw] || eventTypeRaw;\n\nconst exactMatrix = {\n  'CRITICAL::ROAD_CLOSURE': { riskLevel: 'HIGH', riskColor: 'red', recommendedAction: 'Reroute immediately and notify operations/driver' },\n  'HIGH::TRAFFIC_JAM': { riskLevel: 'MEDIUM', riskColor: 'orange', recommendedAction: 'Calculate detour and monitor ETA impact' },\n  'LOW::WEATHER_ALERT': { riskLevel: 'LOW', riskColor: 'yellow', recommendedAction: 'Monitor conditions and keep current route' }\n};\n\nconst severityFallback = {\n  CRITICAL: { riskLevel: 'HIGH', riskColor: 'red', recommendedAction: 'Reroute immediately and notify operations/driver' },\n  HIGH: { riskLevel: 'MEDIUM', riskColor: 'orange', recommendedAction: 'Calculate detour and monitor ETA impact' },\n  MEDIUM: { riskLevel: 'MEDIUM', riskColor: 'orange', recommendedAction: 'Assess detour options and continue monitoring' },\n  LOW: { riskLevel: 'LOW', riskColor: 'yellow', recommendedAction: 'Monitor conditions and keep current route' }\n};\n\nconst gatewayEventTypeMap = {\n  TRAFFIC_JAM: 'traffic_jam',\n  ROAD_CLOSURE: 'traffic_jam',\n  WEATHER_ALERT: 'weather_change'\n};\nconst gatewayEventType = gatewayEventTypeMap[eventType] || 'traffic_jam';\n\nconst key = `${severity}::${eventType}`;\nconst result = exactMatrix[key] || severityFallback[severity] || severityFallback.MEDIUM;\n\nreturn [{\n  json: {\n    ...payload,\n    severity,\n    gatewayEventType,\n    risk: {\n      eventType,\n      severity,\n      riskLevel: result.riskLevel,\n      riskColor: result.riskColor,\n      recommendedAction: result.recommendedAction\n    }\n  }\n}];"
      },
      "id": "a1b2c3d4-0010-0010-0010-000000000010",
      "name": "Evaluate Risk Matrix",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [570, 120]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://maps.googleapis.com/maps/api/geocode/json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "address",
              "value": "={{ $json.locationDescription || $json.location?.description || 'Autopista Norte - Calle 100, Bogota, Colombia' }}"
            },
