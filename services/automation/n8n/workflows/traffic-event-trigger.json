              "name": "key",
              "value": "={{ $env.GOOGLE_MAPS_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
      "name": "Get Detour Alternatives",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const payload = $('Evaluate Risk Matrix').item.json;\nconst geocodeItem = $('Geocode Incident').item ?? {};\nconst directionsItem = $('Get Detour Alternatives').item ?? {};\n\nconst geocode = geocodeItem.json ?? {};\nconst directions = directionsItem.json ?? {};\nconst geocodeError = geocodeItem.error ?? null;\nconst directionsError = directionsItem.error ?? null;\n\nconst blockedStatuses = ['REQUEST_DENIED', 'OVER_QUERY_LIMIT'];\nconst geocodeStatus = geocode.status ?? 'UNKNOWN';\nconst directionsStatus = directions.status ?? 'UNKNOWN';\nconst geocodeBlocked = blockedStatuses.includes(geocodeStatus);\nconst directionsBlocked = blockedStatuses.includes(directionsStatus);\n\nconst mapsFallback = Boolean(geocodeError || directionsError || geocodeBlocked || directionsBlocked);\n\nconst routes = Array.isArray(directions.routes) ? directions.routes : [];\nconst bestRoute = routes[0] || null;\nconst alternativeRoutes = mapsFallback ? 0 : Math.max(routes.length - 1, 0);\n\nlet incidentLocation = null;\nlet formattedAddress = payload.locationDescription || payload.location?.description || null;\nif (!mapsFallback && Array.isArray(geocode.results) && geocode.results.length > 0) {\n  const first = geocode.results[0];\n  formattedAddress = first.formatted_address ?? formattedAddress;\n  incidentLocation = first.geometry?.location ?? null;\n}\n\nconst durationInTrafficSec = mapsFallback ? null : (bestRoute?.legs?.[0]?.duration_in_traffic?.value ?? bestRoute?.legs?.[0]?.duration?.value ?? null);\nconst distanceMeters = mapsFallback ? null : (bestRoute?.legs?.[0]?.distance?.value ?? null);\n\nconst detourRecommended = mapsFallback ? false : alternativeRoutes > 0;\nconst legacyStops = Array.isArray(payload.stops) ? payload.stops : [];\nconst jobs = legacyStops.map((stop) => ({\n  id: String(stop.id),\n  location: {\n    lat: Number(stop.lat),\n    lon: Number(stop.lng),\n  },\n  amount: Number(stop.demand ?? 0),\n  priority: Number(stop.priority ?? 0),\n  service: 0,\n  skills: [],\n  timeWindowStart: 0,\n  timeWindowEnd: 4294967295,\n}));\n\nreturn [{\n  json: {\n    eventType: payload.gatewayEventType || payload.eventType,\n    sourceEventType: payload.eventType,\n    severity: payload.severity,\n    risk: payload.risk,\n    vehicles: payload.vehicles,\n    stops: legacyStops,\n    jobs,\n    options: {\n      geometry: false,\n      metric: 'duration',\n      optimize: true,\n      algorithm: 'greedy',\n      maxJobsPerRoute: 0\n    },\n    maps: {\n      geocodingStatus: geocodeStatus,\n      directionsStatus: directionsStatus,\n      fallbackApplied: mapsFallback,\n      fallbackReason: mapsFallback ? (geocodeError?.message || directionsError?.message || geocodeStatus || directionsStatus) : null,\n      incidentAddress: formattedAddress,\n      incidentLocation,\n      alternativeRoutes,\n      detourRecommended,\n      bestRoute: {\n        durationInTrafficSec,\n        distanceMeters\n      }\n    }\n  }\n}];"
      },
