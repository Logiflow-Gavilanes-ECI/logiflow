FROM node:20-alpine

RUN apk add --no-cache git python3 make g++

WORKDIR /app

RUN git clone --depth 1 https://github.com/VROOM-Project/vroom-express.git .

# Build vroom-express dependencies and the vroom binary in postinstall.
RUN npm pkg delete scripts.prepare && npm install --omit=dev

EXPOSE 3000

CMD ["node", "src/index.js"]