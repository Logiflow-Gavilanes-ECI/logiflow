# Optimizer service configuration

# Required for live Google Routes requests (when GOOGLE_ROUTES_ENABLED=true and GOOGLE_ROUTES_ALLOW_CALLS=true)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Internal service URLs and ports
VROOM_URL=http://vroom:3000
GRPC_PORT=50051
REDIS_URL=redis://redis:6379

# Matrix strategy
# request -> use matrix from gRPC payload
# google  -> build matrix from Google Routes
MATRIX_SOURCE=request

# Google Routes feature toggles
GOOGLE_ROUTES_ENABLED=false
GOOGLE_ROUTES_ALLOW_CALLS=false
GOOGLE_ROUTES_MOCK=true

# Safety limit for matrix size (N x N where N is locations count)
MAX_GOOGLE_MATRIX_LOCATIONS=10

# AI traffic predictor integration
AI_PREDICTOR_ENABLED=false
AI_PREDICTOR_URL=http://ai-predictor:5001/adjust
AI_PREDICTOR_TIMEOUT_MS=5000
