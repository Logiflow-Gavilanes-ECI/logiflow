# AI Traffic Predictor — environment configuration

# Bind port. The optimizer expects ai-predictor:5001 in the docker-compose
# network. Override only if you change the compose service name/port.
PORT=5001

# Gunicorn tuning. Workers should typically be (2 * CPU) + 1 for sync
# workers. The predictor is CPU-light, so 2 is enough on a t3.medium.
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30

# Log level passed both to gunicorn and to structlog (debug|info|warning|error).
LOG_LEVEL=info

# Optional shared-secret enforced on POST /adjust. When set, the optimizer
# must send `X-Internal-Token: <value>` or the request is rejected with 401.
# Leave empty to disable auth (only acceptable when the service is bound to
# a private VPC subnet).
INTERNAL_TOKEN=
